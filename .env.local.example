# Copy this to .env.local and fill in your values

# Supabase — supabase.com > project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — resend.com/api-keys
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Scout <scout@yourdomain.com>

# Telegram — @BotFather on Telegram > /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-xxxx

# Discord — discord.com/developers/applications > your app > Bot > Token
DISCORD_BOT_TOKEN=your-discord-bot-token

# Your deployed URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://scout.vercel.app

# Cron security — Vercel sets this automatically in production
# For local testing: generate any random string
CRON_SECRET=generate-a-random-string-here

# BYOK encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BYOK_ENCRYPTION_KEY=64-hex-chars-here
